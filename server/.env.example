# Neon database connection string
# Dapatkan dari: https://console.neon.tech > Project > Connection Details
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Neon Auth Base URL — URL upstream Neon Auth instance Anda
# Dapatkan dari: Neon Console > Project > Auth > "Auth URL"
NEON_AUTH_BASE_URL=https://auth.neon.tech/your-project-id

# Neon Auth Cookie Secret — min 32 karakter untuk sign session cookies
# Generate dengan: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=ganti-dengan-secret-random-min-32-karakter-panjang

# Port server (default: 3001)
PORT=3001

# URL frontend untuk CORS
CLIENT_URL=http://localhost:5173

# Nomor WhatsApp untuk payment manual (format: 62xxx tanpa +)
WHATSAPP_NUMBER=6281234567890
