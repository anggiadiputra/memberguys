# URL API server (via Vite proxy, jangan ubah jika dev lokal)
# Vite proxy /api → http://localhost:3001 sudah dikonfigurasi di vite.config.ts
VITE_API_URL=/api

# URL Neon Auth Asli
# Dapatkan dari: console.neon.tech > Project > Auth > Auth URL
# PENTING: Gunakan URL dari Neon (https://auth.neon.tech/...)
# BUKAN dari API Anda sendiri
VITE_AUTH_URL=https://auth.neon.tech/ganti-dengan-project-anda
